{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/source-manifest.schema.json",
  "title": "Source Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "protocol",
    "source_database",
    "search_date",
    "query_version",
    "native_export_path",
    "normalized_csv_path",
    "record_count_raw",
    "record_count_imported",
    "status"
  ],
  "properties": {
    "run_id": { "type": "string" },
    "protocol": { "type": "string", "enum": ["A", "B"] },
    "source_database": { "type": "string" },
    "source_database_detail": { "type": ["string", "null"] },
    "search_date": { "type": "string", "format": "date" },
    "query_version": { "type": "string" },
    "native_export_path": { "type": "string" },
    "normalized_csv_path": { "type": "string" },
    "record_count_raw": { "type": "integer", "minimum": 0 },
    "record_count_imported": { "type": "integer", "minimum": 0 },
    "status": { "type": "string", "enum": ["pending", "ready", "failed", "archived"] },
    "peer_review_status": { "type": ["string", "null"] },
    "notes": { "type": ["string", "null"] }
  }
}
